{
	"name": "dotnotes",
	"description": "dotNotes personal note app built with Cloudflare Workers, Hono, React Router, and shadcn/ui",
	"cloudflare": {
		"label": "React Router + Hono Fullstack App",
		"products": [
			"Workers"
		],
		"categories": [
			"starter"
		],
		"docs_url": "https://developers.cloudflare.com/workers",
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/d3db20ee-c3bf-4b5c-f1ed-d86021359e00/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/56caa8a9-d3ab-4ac6-32a9-6a5fc686e000/preview",
		"publish": true
	},
	"dependencies": {
		"@codemirror/lang-markdown": "^6.5.0",
		"@uiw/react-codemirror": "^4.25.7",
		"hono": "4.11.1",
		"isbot": "5.1.32",
		"node-html-markdown": "^2.0.0",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"react-markdown": "^10.1.0",
		"react-router": "7.9.6",
		"remark-gfm": "^4.0.1"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "1.15.3",
		"@react-router/dev": "7.9.6",
		"@tailwindcss/vite": "4.1.17",
		"@types/node": "^24.10.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"better-sqlite3": "^12.6.2",
		"tailwindcss": "4.1.17",
		"typescript": "5.9.3",
		"vite": "^6.0.0",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "^3.2.4",
		"wrangler": "^4.69.0"
	},
	"private": true,
	"scripts": {
		"build": "XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-/tmp/dotnotes-codex-config} react-router build",
		"cf-typegen": "XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-/tmp/dotnotes-codex-config} wrangler types",
		"deploy": "XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-/tmp/dotnotes-codex-config} npm run build && XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-/tmp/dotnotes-codex-config} wrangler deploy",
		"dev": "XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-/tmp/dotnotes-codex-config} react-router dev",
		"preview": "npm run build && vite preview",
		"test": "XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-/tmp/dotnotes-codex-config} vitest run",
		"typecheck": "XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-/tmp/dotnotes-codex-config} npm run cf-typegen && XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-/tmp/dotnotes-codex-config} react-router typegen && tsc -b"
	},
	"type": "module"
}
